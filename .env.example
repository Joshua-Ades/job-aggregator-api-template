# ─────────────────────────────────────────────
# Django
# ─────────────────────────────────────────────
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=*

# ─────────────────────────────────────────────
# PostgreSQL
# ─────────────────────────────────────────────
POSTGRES_USER=appuser
POSTGRES_PASSWORD=changeme
POSTGRES_DB=jobsdb
DATABASE_URL=postgresql://appuser:changeme@db:5432/jobsdb

# ─────────────────────────────────────────────
# Redis (cache + Celery broker)
# ─────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─────────────────────────────────────────────
# AI Provider — pick ONE, set the matching key
# ─────────────────────────────────────────────
AI_PROVIDER=claude          # options: "claude" | "openai" | "gemini"

# Claude → https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_key_here
CLAUDE_MODEL=claude-haiku-4-5-20251001

# OpenAI (ChatGPT) → https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_key_here
OPENAI_MODEL=gpt-4o-mini

# Gemini → https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-1.5-flash

# ─────────────────────────────────────────────
# Job Data Source — pick ONE provider
# Both use the same RapidAPI key
# ─────────────────────────────────────────────
RAPIDAPI_KEY=your_rapidapi_key_here

# OPTION A: LinkedIn Scraper (50 req/month free)
RAPIDAPI_HOST=linkedin-scraper-api-real-time-fast-affordable.p.rapidapi.com
JOB_API_PROVIDER=linkedin

# OPTION B: JSearch (200 req/month free — recommended)
# RAPIDAPI_HOST=jsearch.p.rapidapi.com
# JOB_API_PROVIDER=jsearch

# ─────────────────────────────────────────────
# Fetch config — change these to target any role or location
# Examples:
#   JOB_SEARCH_QUERY=Registered Nurse       JOB_SEARCH_LOCATION=London
#   JOB_SEARCH_QUERY=Marketing Manager      JOB_SEARCH_LOCATION=New York
#   JOB_SEARCH_QUERY=DevOps Engineer        JOB_SEARCH_LOCATION=Germany
#   JOB_SEARCH_QUERY=Data Scientist         JOB_SEARCH_LOCATION=Remote
# ─────────────────────────────────────────────
JOB_SEARCH_QUERY=Python Backend Developer
JOB_SEARCH_LOCATION=Israel

# ─────────────────────────────────────────────
# Cache
# ─────────────────────────────────────────────
SUMMARY_CACHE_TTL=3600
